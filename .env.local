# Local development overrides — Vite loads this file before .env
# Points to the local backend instead of the production server.
VITE_BACKEND_BASE_URL=http://localhost:3001/api/v1
VITE_SOCKET_BASE_URL=http://localhost:3001
VITE_SOCKET_PATH=/socket.io
VITE_BACKEND_ENABLED=true
VITE_FRONTEND_ONLY_MODE=false
VITE_ENABLE_COMPAT_BOOTSTRAP=true
